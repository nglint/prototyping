double normalize_angle(double theta) {
    theta = fmod(theta + M_PI, 2 * M_PI);
    if (theta < 0) {
        theta += 2 * M_PI;
    }
    return theta - M_PI;
}

double subtract_angles(double a, double b) {
    return normalize_angle(a - b);
}

