#include <arm_neon.h>
#include <iostream>
#include <vector>

void conv(double *H, short *A, int N, int len) {
    // 1. Prepare float buffers (NEON is fastest with 32-bit floats)
    // We pad the input signal with (N-1) zeros to avoid boundary checks
    int padded_len = len + 2 * (N - 1);
    std::vector<float> A_float(padded_len, 0.0f);
    std::vector<float> H_float(N);

    // Copy signal into the middle of the padded buffer
    for (int i = 0; i < len; i++) A_float[i + (N - 1)] = (float)A[i];
    
    // Reverse Taps (H) once so we can use a Dot Product instead of a sliding window
    // This allows sequential memory loading which is MUCH faster.
    for (int i = 0; i < N; i++) H_float[i] = (float)H[N - 1 - i];

    // Allocate result buffer
    std::vector<float> B(len + N - 1, 0.0f);

    // 2. Main NEON Loop
    for (int I = 0; I < len + N - 1; I++) {
        float32x4_t sum_vec = vdupq_n_f32(0.0f);
        float const* a_ptr = &A_float[I];
        float const* h_ptr = H_float.data();
        
        int i = 0;
        // Process 4 taps at a time
        for (; i <= N - 4; i += 4) {
            float32x4_t a_v = vld1q_f32(a_ptr + i);
            float32x4_t h_v = vld1q_f32(h_ptr + i);
            sum_vec = vmlaq_f32(sum_vec, a_v, h_v);
        }

        // Horizontal sum of the 4 lanes
        float res = vgetq_lane_f32(sum_vec, 0) + vgetq_lane_f32(sum_vec, 1) +
                    vgetq_lane_f32(sum_vec, 2) + vgetq_lane_f32(sum_vec, 3);

        // Clean up remaining taps if N is not a multiple of 4
        for (; i < N; i++) {
            res += a_ptr[i] * h_ptr[i];
        }
        B[I] = res;
    }

    // 3. Match your original output logic
    int p = (N - 1) / 2;
    for (int i = 0; i < len; i++) {
        A[i] = (short)B[i + p];
    }
}
