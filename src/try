#include <arm_neon.h>
#include <vector>
#include <algorithm>

void conv_neon_fast(
    const float * __restrict H,   // filter taps
    const float * __restrict A,   // input signal
    short * __restrict output_A,  // output
    int N, int len)
{
    int total_len = len + N - 1;

    // Reverse H for forward access
    std::vector<float> H_rev(N);
    for (int i = 0; i < N; i++)
        H_rev[i] = H[N - 1 - i];

    // Zero-padded input (important!)
    std::vector<float> A_pad(len + N - 1, 0.0f);
    for (int i = 0; i < len; i++)
        A_pad[i + (N - 1)] = A[i];

    // Convolution
    for (int I = 0; I < len; I++) {
        float32x4_t sum_vec = vdupq_n_f32(0.0f);
        int i = 0;

        // Vectorized loop
        for (; i <= N - 4; i += 4) {
            float32x4_t h_vec = vld1q_f32(&H_rev[i]);
            float32x4_t s_vec = vld1q_f32(&A_pad[I + i]);

            sum_vec = vmlaq_f32(sum_vec, h_vec, s_vec);
        }

        // Horizontal sum
        float res = vaddvq_f32(sum_vec);

        // Tail loop
        for (; i < N; i++) {
            res += H_rev[i] * A_pad[I + i];
        }

        // Saturate and store
        res = std::max(-32768.0f, std::min(32767.0f, res));
        output_A[I] = (short)res;
    }
}
